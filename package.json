{
  "name": "chakravyuh",
  "version": "1.0.0",
  "description": "Chakravyuh AI-Powered Security Threat Modeling Platform",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "build": "npm run build --workspace=frontend",
    "start": "npm run start --workspace=frontend",
    "lint": "npm run lint --workspace=frontend",
    "typecheck": "npm run typecheck --workspace=frontend",
    "ci": "npm run lint --workspace=frontend && npm run typecheck --workspace=frontend && npm run build --workspace=frontend",
    "verify:backend": "cd backend && make test",
    "verify": "npm run ci && npm run verify:backend",
    "install:all": "npm install && cd backend && pip install -r requirements.txt",
    "backend": "cd backend && make api",
    "frontend": "npm run dev --workspace=frontend"
  },
  "keywords": [
    "security",
    "threat-modeling",
    "rag",
    "llm",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "yarn@4.11.0+sha512.4e54aeace9141df2f0177c266b05ec50dc044638157dae128c471ba65994ac802122d7ab35bcd9e81641228b7dcf24867d28e750e0bcae8a05277d600008ad54"
}
