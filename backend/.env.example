# Copy to .env (setup-local.sh does this automatically).
# PostgreSQL — match your local or Docker database.

PG_HOST=localhost
PG_PORT=5432
PG_DB=chakravyuh    
PG_USER=chakravyuh
PG_PASSWORD=chakravyuh

# Security controls
AUTH_ENABLED=true
SECURITY_PRODUCTION_MODE=false
JWT_ALGORITHM=HS256
# Shared secret for HS256 (this is NOT the JWT string the browser sends — that goes in the frontend as NEXT_PUBLIC_API_BEARER_TOKEN).
JWT_SECRET=replace-with-a-strong-secret
JWT_AUDIENCE=
JWT_ISSUER=

# Runtime guards
MAX_REQUEST_BYTES=57671680
ENABLE_DEPRECATED_ENDPOINTS=false
