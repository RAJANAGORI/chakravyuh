# Copy to .env.local and adjust. NEXT_PUBLIC_* is exposed to the browser.

# Optional: override API origin (default: same host as the UI, port 8000)
# NEXT_PUBLIC_BACKEND_API_URL=http://127.0.0.1:8000

# When the backend has AUTH_ENABLED=true, set a valid JWT (must match JWT_SECRET / algorithm).
# For local dev you can set AUTH_ENABLED=false in backend/.env instead.
# NEXT_PUBLIC_API_BEARER_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
